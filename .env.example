# MOMO Quant — local / compose environment variable names (no real secrets)

# Copy to .env and fill after credential rotation. Never commit .env.

APP_ENV=Development
APP_URL=http://localhost:5173
ASPNETCORE_ENVIRONMENT=Development

# MySQL
MYSQL_DATABASE=momo_quant
MYSQL_USER=momo_user
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=
ConnectionStrings__DefaultConnection=

# Redis
REDIS_PASSWORD=
ConnectionStrings__Redis=

# JWT
Jwt__Secret=
Jwt__Issuer=MOMOQuant
Jwt__Audience=MomoQuantDashboard
JWT_SECRET=
JWT_ISSUER=MOMOQuant
JWT_AUDIENCE=MomoQuantDashboard

# Development admin seed (Development only)
Seed__AdminEmail=admin@momoquant.local
Seed__AdminPassword=
Seed__AdminFullName=Development Admin

# AI service
AI_SERVICE_URL=http://127.0.0.1:8001
AiService__BaseUrl=http://127.0.0.1:8001

# Optional
ENCRYPTION_KEY=
BINANCE_BASE_URL=https://fapi.binance.com
BINANCE_WS_URL=wss://fstream.binance.com

# Test hosts only — never set in production
# MOMO_SKIP_SECRETS_VALIDATION=true
