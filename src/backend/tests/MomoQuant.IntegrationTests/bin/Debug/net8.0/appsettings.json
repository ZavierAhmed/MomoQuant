{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=3306;Database=momo_quant;User=momo_user;Password=CHANGE_ME;"
  },
  "MarketData": {
    "HistoricalProvider": "Binance",
    "LiveProvider": "Binance",
    "Binance": {
      "BaseUrl": "https://fapi.binance.com",
      "WebSocketBaseUrl": "wss://fstream.binance.com",
      "WebSocketRawBaseUrl": "wss://fstream.binance.com/market/ws",
      "WebSocketCombinedBaseUrl": "wss://fstream.binance.com/market/stream",
      "NoMessageWarningSeconds": 10,
      "ReconnectDelaySeconds": 5,
      "MaxReconnectAttempts": 20,
      "RequestDelayMs": 250,
      "Limit": 1500,
      "MaxDaysPerImport": 30,
      "AllowedSymbols": [
        "BTCUSDT",
        "ETHUSDT",
        "SOLUSDT",
        "BNBUSDT",
        "XRPUSDT"
      ],
      "AllowedIntervals": [
        "1m",
        "3m",
        "5m",
        "15m",
        "30m",
        "1h",
        "4h",
        "1d",
        "1w"
      ]
    },
    "LiveBootstrap": {
      "WarmupCandles": 300,
      "MaxBootstrapCandles": 500,
      "AllowAutoBootstrap": true
    }
  },
  "StrategyCatalog": {
    "SeedDefaultStrategies": false
  },
  "SkSystem": {
    "SwingSensitivity": "Balanced",
    "MinSwingDistancePercent": 0.4,
    "MinSwingCandles": 3,
    "FibonacciCorrectionLevels": [ 0.382, 0.5, 0.559, 0.618, 0.667 ],
    "FibonacciExtensionLevels": [ 1.0, 1.272, 1.618, 2.0 ],
    "GoldenPocketMin": 0.618,
    "GoldenPocketMax": 0.667,
    "UseWicksForSwingPoints": true,
    "MaxSequenceCandidates": 5,
    "RequireHigherTimeframeAgreement": false,
    "AiSummaryEnabledDefault": true
  },
  "BbLiquiditySweep": {
    "Sessions": [
      { "name": "London", "start": "02:00", "end": "05:00", "timezone": "America/New_York" },
      { "name": "New York AM", "start": "08:30", "end": "11:30", "timezone": "America/New_York" },
      { "name": "New York PM", "start": "13:30", "end": "15:30", "timezone": "America/New_York" }
    ]
  },
  "MomoQuant:Exports": {
    "RootPath": "C:\\momo_quants_exports",
    "MaxRowsInPdfTables": 500
  },
  "StrategyBenchmark": {
    "BinanceImportChunkDays": 7,
    "MaxBacktestRunMinutes": 5,
    "ContinueOnRunFailure": true,
    "HeartbeatSeconds": 5,
    "StalledAfterMinutes": 15,
    "SkipImportIfCoverageAlreadyGood": true,
    "SkipImportCoveragePercent": 99,
    "AnchorTimeframes": [
      "4h"
    ]
  },
  "Logging": {
    "FilePath": "C:\\momo_quants_logs",
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "C:\\momo_quants_logs\\momo-quant-api-.log",
          "rollingInterval": "Day"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "C:\\momo_quants_logs\\errors-.log",
          "rollingInterval": "Day",
          "restrictedToMinimumLevel": "Error"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
