        "5m",
        "15m",
        "30m",
        "1h",
        "4h",
        "1d",
        "1w"
      ]
    }
  },
  "StrategyBenchmark": {
    "AnchorTimeframes": [
      "4h"
    ]
  },
  "Logging": {
    "FilePath": "C:\\momo_quants_logs",
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
