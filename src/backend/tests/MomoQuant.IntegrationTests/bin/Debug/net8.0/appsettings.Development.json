{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=3306;Database=momo_quant;User=momo_user;Password=CHANGE_ME;"
  },
  "Jwt": {
    "Secret": "CHANGE_ME_REPLACE_WITH_USER_SECRETS_OR_ENV",
    "Issuer": "MOMOQuant",
    "Audience": "MomoQuantDashboard",
    "ExpirationMinutes": 60
  },
  "Seed": {
    "AdminEmail": "admin@momoquant.local",
    "AdminPassword": "",
    "AdminFullName": "Development Admin"
  },
  "AiService": {
    "BaseUrl": "http://127.0.0.1:8001",
    "TimeoutSeconds": 10,
    "EnableFallback": true
